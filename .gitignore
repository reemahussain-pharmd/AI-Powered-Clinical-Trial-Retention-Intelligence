# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.pyc
*.pyo
*.pyd
*.egg-info/
dist/
build/

# ── Virtual environments ───────────────────────────────────────────────────────
venv/
.venv/
env/
ENV/

# ── Secrets & credentials (NEVER commit these) ────────────────────────────────
.env
.env.*
*.env
secrets.toml
.streamlit/secrets.toml
*.pem
*.key
*.p12
*.pfx
*.crt
*.cer

# ── Streamlit ─────────────────────────────────────────────────────────────────
.streamlit/secrets.toml

# ── MLflow tracking (training artefacts, not needed for serving) ──────────────
mlruns/
catboost_info/

# ── Database files ────────────────────────────────────────────────────────────
*.db
*.sqlite
*.sqlite3

# ── Jupyter ───────────────────────────────────────────────────────────────────
.ipynb_checkpoints/
notebooks/.ipynb_checkpoints/

# ── Test cache ────────────────────────────────────────────────────────────────
.pytest_cache/
.coverage
htmlcov/

# ── Reports (regenerated at runtime) ─────────────────────────────────────────
reports/*.pdf

# ── Logs ──────────────────────────────────────────────────────────────────────
*.log
logs/

# ── OS metadata ───────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini
